<?xml version='1.0' encoding='utf-8'?>
<widget id="com.longevity.game" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>洪荒长生</name>
    <description>以太白金星李长寿为主角的洪荒修仙游戏</description>
    <author email="support@longevitygame.com" href="https://longevitygame.com">
        Longevity Game Team
    </author>
    <content src="index.html" />
    
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    
    <platform name="ios">
        <preference name="AllowInlineMediaPlayback" value="true" />
        <preference name="BackupWebStorage" value="local" />
        <preference name="DisallowOverscroll" value="true" />
        <preference name="EnableViewportScale" value="false" />
        <preference name="KeyboardDisplayRequiresUserAction" value="false" />
        <preference name="MediaPlaybackRequiresUserAction" value="false" />
        <preference name="SuppressesIncrementalRendering" value="true" />
        <preference name="WebSecurityEnabled" value="false" />
        <preference name="Orientation" value="landscape" />
        <preference name="AutoHideSplashScreen" value="true" />
        <preference name="ShowSplashScreenSpinner" value="false" />
        <preference name="SplashScreenDelay" value="3000" />
        
        <icon src="www/img/icon-180.png" width="180" height="180" />
        <icon src="www/img/icon-120.png" width="120" height="120" />
        <icon src="www/img/icon-87.png" width="87" height="87" />
        <icon src="www/img/icon-80.png" width="80" height="80" />
        <icon src="www/img/icon-72.png" width="72" height="72" />
        <icon src="www/img/icon-58.png" width="58" height="58" />
        <icon src="www/img/icon-57.png" width="57" height="57" />
        
        <splash src="www/img/splash-2732x2732.png" width="2732" height="2732" />
        <splash src="www/img/splash-2436x2436.png" width="2436" height="2436" />
        <splash src="www/img/splash-1668x2388.png" width="1668" height="2388" />
        <splash src="www/img/splash-1536x2048.png" width="1536" height="2048" />
        
        <feature name="StatusBar">
            <param name="ios-package" onload="true" value="CDVStatusBar" />
        </feature>
        
        <config-file parent="NSAppTransportSecurity" platform="ios" target="*-Info.plist">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true/>
            </dict>
        </config-file>
        
        <config-file parent="UIViewControllerBasedStatusBarAppearance" platform="ios" target="*-Info.plist">
            <false/>
        </config-file>
    </platform>
    
    <plugin name="cordova-plugin-whitelist" spec="1.3.4" />
    <plugin name="cordova-plugin-statusbar" spec="2.4.3" />
    <plugin name="cordova-plugin-splashscreen" spec="5.0.4" />
</widget>